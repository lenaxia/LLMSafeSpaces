{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "LLMSafeSpaces billing and cost attribution: inference spend, token economics, per-user/per-workspace usage, quota enforcement. Pipeline health is on the Operational dashboard.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [
        "llmsafespaces"
      ],
      "targetBlank": true,
      "title": "LLMSafeSpaces Dashboards",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "Burn Rate (Fleet-wide Inference Spend)",
      "type": "row",
      "description": "How fast are we spending on inference? Total cost, cost by model, cost by tier. These panels answer: what is driving spend, and is the free tier costing more than expected?"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(llmsafespaces_inference_cost_dollars_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__range]))",
          "refId": "A"
        }
      ],
      "title": "Total Inference Cost (period)",
      "type": "stat",
      "description": "Cumulative inference spend in USD over the dashboard time range. Zero for providers that do not report cost (self-hosted, relay models). Red threshold at $500/period \u2014 adjust to match your daily budget. If spend exceeds budget, check Cost Rate by Model to identify which model is driving it."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(llmsafespaces_inference_requests_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__range]))",
          "refId": "A"
        }
      ],
      "title": "Total Inference Requests (period)",
      "type": "stat",
      "description": "Number of inference calls that produced at least one output token in the selected period. Use with Total Cost to compute cost-per-request. A high request count with low cost indicates cheap models are being used; low requests with high cost indicates expensive models."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(llmsafespaces_inference_input_tokens_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__range]))",
          "refId": "A"
        }
      ],
      "title": "Total Input Tokens (period)",
      "type": "stat",
      "description": "Total prompt tokens sent to models. A high input-to-output ratio indicates long-context sessions (large codebases being re-submitted). This is the secondary cost driver for token-priced providers."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(increase(llmsafespaces_inference_output_tokens_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__range]))",
          "refId": "A"
        }
      ],
      "title": "Total Output Tokens (period)",
      "type": "stat",
      "description": "Total tokens generated by models. This is the PRIMARY cost driver for token-priced providers. Compare with Input Tokens to understand the prompt-vs-generation economics."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "unit": "$/h"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(llmsafespaces_inference_cost_dollars_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__rate_interval])) by (model_id) * 3600",
          "legendFormat": "{{model_id}}",
          "refId": "A"
        }
      ],
      "title": "Cost Rate by Model ($/h)",
      "type": "timeseries",
      "description": "Inference spend rate in USD per hour for each model. A flat line = steady usage. A rising line = an active session consuming tokens. A single model dominating this chart is the primary cost lever \u2014 consider offering a cheaper alternative or adjusting free-tier model availability. Action: negotiate pricing with provider, limit expensive models to paid tiers."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "unit": "$/h"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "free"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "paid"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(llmsafespaces_inference_cost_dollars_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__rate_interval])) by (tier) * 3600",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "title": "Cost Rate by Tier \u2014 Free vs Paid ($/h, stacked)",
      "type": "timeseries",
      "description": "Inference spend split by credential tier. Free (yellow) = calls routed through opencode relay (platform bears the cost). Paid (green) = calls using user's own provider credentials (user bears the cost). If free-tier cost is growing, the platform is subsidizing inference for free users. Action: tighten free-tier model availability, enforce token quotas, or convert free users to paid."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 8,
      "panels": [],
      "title": "Per-User Attribution (from usage_events table)",
      "type": "row",
      "description": "Who is costing the most? Top consumers by tokens and compute time. These panels query the PostgreSQL usage_events table directly, enabling per-user attribution that Prometheus cardinality limits prevent. Requires the Postgres datasource to be configured in Grafana."
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${pg_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 10000000
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "id": 9,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${pg_datasource}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT owner_id AS metric, SUM(quantity) AS value FROM usage_events WHERE event_type = 'llm_tokens' AND owner_type = 'user' AND event_time BETWEEN $__timeFrom() AND $__timeTo() GROUP BY owner_id ORDER BY value DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top-10 Users by Token Consumption",
      "type": "bargauge",
      "description": "Top-10 users by total token consumption (input + output) in the selected period. Red threshold at 10M tokens. A single user dominating this chart is the primary cost driver. Action: enforce per-user token quota, upsell to paid tier, investigate for abuse (automated loops, token farming)."
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${pg_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "unit": "h"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "id": 10,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${pg_datasource}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT owner_id AS metric, SUM(quantity) / 3600.0 AS value FROM usage_events WHERE event_type = 'compute_seconds' AND owner_type = 'user' AND event_time BETWEEN $__timeFrom() AND $__timeTo() GROUP BY owner_id ORDER BY value DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top-10 Users by Compute Hours",
      "type": "bargauge",
      "description": "Top-10 users by active workspace compute hours in the selected period. Red threshold at 100h. Users with very high compute hours may be running workspaces idle (wasting PVC storage and node capacity). Action: enforce idle-eviction policy, implement compute-hour quotas, contact user about usage patterns."
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${pg_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "id": 11,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${pg_datasource}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT workspace_id AS metric, SUM(quantity) / 3600.0 AS value FROM usage_events WHERE event_type = 'compute_seconds' AND workspace_id IS NOT NULL AND event_time BETWEEN $__timeFrom() AND $__timeTo() GROUP BY workspace_id ORDER BY value DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top-10 Workspaces by Compute Hours",
      "type": "bargauge",
      "description": "Top-10 individual workspaces by compute hours. Red threshold at 500h. A single workspace with very high compute hours is a candidate for suspension if idle, or resource-limit adjustment if actively used. Action: check if workspace is actively used (session activity), suspend long-idle workspaces, adjust resource requests."
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${pg_datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1,
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "id": 12,
      "options": {
        "displayMode": "lcd",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${pg_datasource}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ul.owner_id || ' / ' || ul.event_type AS metric, COALESCE(SUM(ue.quantity), 0)::float / NULLIF(ul.max_quantity, 0) * 100 AS value FROM usage_limits ul LEFT JOIN usage_events ue ON ue.owner_id = ul.owner_id AND ue.owner_type = ul.owner_type AND ue.event_type = ul.event_type AND ue.period = CURRENT_DATE WHERE ul.period_type = 'daily' GROUP BY ul.owner_id, ul.event_type, ul.max_quantity HAVING COALESCE(SUM(ue.quantity), 0)::float / NULLIF(ul.max_quantity, 0) > 0 ORDER BY value DESC LIMIT 10",
          "refId": "A"
        }
      ],
      "title": "Top-10 Users by Daily Quota Utilization %",
      "type": "bargauge",
      "description": "Top-10 users approaching their daily quota limit for any event type. Red threshold at 90%: users above this will soon hit their quota and start receiving 429s. Action: proactively contact high-usage users for upsell, review if quota limits are appropriate for the usage pattern."
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 13,
      "panels": [],
      "title": "Token Economics & Model Mix",
      "type": "row",
      "description": "Which models are being used and how efficiently? Token throughput, model selection patterns, and request distribution by provider. Use these to optimize model offerings and identify token inefficiency."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "unit": "tok/s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "id": 14,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(llmsafespaces_inference_input_tokens_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__rate_interval])) by (model_id)",
          "legendFormat": "input {{model_id}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(llmsafespaces_inference_output_tokens_total{job=~\"__LLMSAFESPACES_API_JOB__\"}[$__rate_interval])) by (model_id)",
          "legendFormat": "output {{model_id}}",
          "refId": "B"
        }
      ],
      "title": "Token Throughput by Model (input vs output)",
      "type": "timeseries",
